<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA">

    <!-- HEADER BACKGROUND -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="220dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#121417"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <!-- subtle accent -->

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:alpha="0.12"
                android:background="@drawable/bg_balance_badge"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- STATUS -->

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_glass"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="BOOKED"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- CUSTOMER -->

            <TextView
                android:id="@+id/tvCustomerHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="Hardik Vora"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintEnd_toStartOf="@id/btnCallCustomer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvStatus"/>

            <!-- PHONE -->

            <TextView
                android:id="@+id/tvPhoneHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="+91 9876543210"
                android:textColor="#B0BEC5"
                android:textSize="15sp"
                android:letterSpacing="0.03"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvCustomerHeader"/>

            <!-- CALL BUTTON -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCallCustomer"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginTop="18dp"
                app:backgroundTint="#FFFFFF"
                app:icon="@android:drawable/ic_menu_call"
                app:iconSize="26dp"
                app:iconTint="#121417"
                app:layout_constraintBottom_toBottomOf="@id/tvPhoneHeader"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvCustomerHeader"/>

            <!-- ORDER META -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="ORD2026-001"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-24dp"
        android:background="@drawable/bg_sheet_top_rounded"
        android:elevation="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnMarkReceived"
        app:layout_constraintTop_toBottomOf="@id/headerBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">



            <LinearLayout
                android:id="@+id/layoutItemTimeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />


            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EAECF0"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:text="Total Rent" android:textColor="#667085" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/detTotal" android:text="₹ 3000" android:textStyle="bold" android:textColor="#1D2939" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" android:layout_width="wrap_content" android:layout_height="wrap_content" />

                        <TextView android:id="@+id/lblDep" android:layout_marginTop="12dp" android:text="Deposit" android:textColor="#667085" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/detTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/detDeposit" android:text="₹ 500" android:textColor="#3949AB" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/lblDep" android:layout_width="wrap_content" android:layout_height="wrap_content" />

                        <TextView android:id="@+id/lblPaid" android:layout_marginTop="12dp" android:text="Rent Paid ₹" android:textColor="#667085" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/detDeposit" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <TextView android:id="@+id/detAdvance" android:text="₹ 2000" android:textColor="#2E7D32" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/lblPaid" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F2F4F7" android:layout_marginVertical="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="OUTSTANDING BALANCE"
                        android:textColor="#D32F2F"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/detBalance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="₹ 1500"
                        android:textColor="#B71C1C"
                        android:textSize="24dp"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendWhatsapp"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="SHARE DETAILS"
                android:textColor="#3949AB"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_menu_share"
                app:iconTint="#3949AB" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickedUp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="MARK AS PICKED UP"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:backgroundTint="#00897B"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelBooking"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:text="Cancel Booking"
                android:textColor="#D32F2F" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnMarkReceived"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_margin="20dp"
        android:text="MARK AS RECEIVED"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:fontFamily="sans-serif-bold"
        app:backgroundTint="#1E88E5"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>