<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:paddingBottom="32dp">

    <View
        android:layout_width="4dp"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:background="#800020"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/lblHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:fontFamily="serif"
        android:text="New Item"
        android:textColor="#1A1C1E"
        android:textSize="28sp"
        android:textStyle="italic|bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.2"
        android:text="SWADHA ARCHIVE"
        android:textColor="#BDBDBD"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/lblHeader"
        app:layout_constraintTop_toBottomOf="@id/lblHeader" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/lblHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <EditText
                android:id="@+id/etDialogItemNo"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:background="@drawable/bg_minimal_line"
                android:gravity="center"
                android:hint="CODE"
                android:inputType="textCapCharacters"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etDialogItemName"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="2"
                android:background="@drawable/bg_minimal_line"
                android:hint="Cloth Name"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <EditText
                android:id="@+id/etDialogRent"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_minimal_line"
                android:hint="Rent (₹)"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp" />

            <EditText
                android:id="@+id/etDialogDeposit"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_minimal_line"
                android:hint="Deposit (₹)"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbDialogRequiresWash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Requires Washing"
            android:textColor="#1A1C1E"
            android:textStyle="bold"
            android:checked="true"/>

        <Button
            android:id="@+id/btnSaveItem"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#0A0A0A"
            android:letterSpacing="0.1"
            android:text="Add Item"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>