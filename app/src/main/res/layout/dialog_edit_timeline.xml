<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FCFAF7"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- HEADER -->

    <TextView
        android:id="@+id/tvItemTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MD08"
        android:textColor="#1A1C1E"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Configure pickup and return schedule"
        android:textColor="#7A7A7A"
        android:textSize="13sp"/>

    <!-- PICKUP CARD -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="#EFE7DC"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pickup Schedule"
                android:textColor="#1A1C1E"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="When customer will receive item"
                android:textColor="#7A7A7A"
                android:textSize="12sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickupDate"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:text="01 Apr 2026"
                    android:textAllCaps="false"
                    android:textColor="#1A1C1E"
                    app:backgroundTint="#F5F5F5"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_calendar"
                    app:iconTint="#1A1C1E"/>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickupTime"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:text="10:30 AM"
                    android:textAllCaps="false"
                    android:textColor="#1A1C1E"
                    app:backgroundTint="#F5F5F5"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_time"
                    app:iconTint="#1A1C1E"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- RETURN CARD -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        app:cardBackgroundColor="#FFF8F6"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="#FAD7D2"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Return Schedule"
                android:textColor="#D32F2F"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Expected item return from customer"
                android:textColor="#C16D63"
                android:textSize="12sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReturnDate"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:text="02 Apr 2026"
                    android:textAllCaps="false"
                    android:textColor="#D32F2F"
                    app:backgroundTint="#FFF1F0"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_calendar"
                    app:iconTint="#D32F2F"/>

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReturnTime"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:text="10:30 AM"
                    android:textAllCaps="false"
                    android:textColor="#D32F2F"
                    app:backgroundTint="#FFF1F0"
                    app:cornerRadius="18dp"
                    app:icon="@drawable/ic_time"
                    app:iconTint="#D32F2F"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>