<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tvItemTitle"
        android:text="Item : MD08"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#1A1C1E"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnPickupDate"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:text="01 Apr 2026"
        android:textColor="#1A1C1E"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_calendar"
        app:iconTint="#1A1C1E"
        app:strokeColor="#E0E2E6" />

    <Button
        android:id="@+id/btnPickupTime"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="22:11"
        android:textColor="#1A1C1E"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_time"
        app:iconTint="#1A1C1E"
        app:strokeColor="#E0E2E6" />

    <Button
        android:id="@+id/btnReturnDate"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:text="02 Apr 2026"
        android:textColor="#D32F2F"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_calendar"
        app:iconTint="#D32F2F"
        app:strokeColor="#FEE4E2"
        app:backgroundTint="#FFF1F0" />

    <Button
        android:id="@+id/btnReturnTime"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:text="22:12"
        android:textColor="#D32F2F"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_time"
        app:iconTint="#D32F2F"
        app:strokeColor="#FEE4E2"
        app:backgroundTint="#FFF1F0" />

</LinearLayout>