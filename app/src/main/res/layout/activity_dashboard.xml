<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <View
            android:id="@+id/titleBarBackground"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#0A0A0A"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_inventory"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="@id/titleBarBackground"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/titleBarBackground"/>

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:letterSpacing="0.2"
            android:text="SVADHA"
            android:textColor="#FFFFFF"
            android:textSize="14dp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/titleBarBackground"
            app:layout_constraintStart_toEndOf="@id/btnMenu"
            app:layout_constraintTop_toTopOf="@id/titleBarBackground" />

        <TextView
            android:id="@+id/tvTotalBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_balance_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="₹ 14,500"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvAppName"
            app:layout_constraintStart_toEndOf="@id/tvAppName"
            app:layout_constraintTop_toTopOf="@id/tvAppName" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            app:layout_constraintBottom_toBottomOf="@id/tvAppName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvAppName">

        </LinearLayout>

        <TextView
            android:id="@+id/tvReturnCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="24dp"
            android:fontFamily="sans-serif-condensed-light"
            android:text="00"
            android:textColor="#1A1C1E"
            android:textSize="60sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleBarBackground" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="15sp"
            android:letterSpacing="0.2"
            android:text="RETURNS"
            android:textColor="#8E8E93"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvReturnCount"
            app:layout_constraintStart_toEndOf="@id/tvReturnCount" />

        <TextView
            android:id="@+id/tvPickupTodayCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="80dp"
            android:fontFamily="sans-serif-condensed-light"
            android:text="00"
            android:textColor="#800020"
            android:textSize="60dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvReturnCount" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="15sp"
            android:letterSpacing="0.2"
            android:text="PICKUPS"
            android:textColor="#8E8E93"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvPickupTodayCount"
            app:layout_constraintStart_toEndOf="@id/tvPickupTodayCount" />

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:padding="0dp"
            android:minHeight="0dp"
            android:background="@drawable/bg_soft_search"
            app:iconifiedByDefault="false"
            app:queryHint="Track code or mobile..."
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvReturnCount" />

        <TextView
            android:id="@+id/labelList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:letterSpacing="0.2"
            android:text="UPCOMING TIMELINE"
            android:textColor="#BDBDBD"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/searchView"
            app:layout_constraintTop_toBottomOf="@id/searchView" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDailyReturns"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:paddingBottom="100dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/labelList" />

        <LinearLayout
            android:id="@+id/layoutEmptyTips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:background="@drawable/bg_premium_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/searchView"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvTipEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👗"
                android:textSize="42sp"/>

            <TextView
                android:id="@+id/tvTipTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Fashion Tip"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvTipText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="Silk outfits should always be stored in breathable garment covers."
                android:textColor="#616161"
                android:textSize="14sp"/>

        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabNewBooking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            android:src="@android:drawable/ic_input_add"
            app:backgroundTint="#0A0A0A"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#17181C"
        app:itemIconTint="@color/drawer_icon_selector"
        app:itemHorizontalPadding="18dp"
        app:itemVerticalPadding="10dp"
        app:itemBackground="@drawable/drawer_item_selector"
        app:headerLayout="@layout/nav_header_dashboard"
        app:itemTextColor="@color/drawer_text_selector"
        app:menu="@menu/dashboard_drawer_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>

