<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FCFAF7"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- HEADER -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Return Items"
        android:textColor="#1A1C1E"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Select the items received from customer"
        android:textColor="#7A7A7A"
        android:textSize="13sp"/>

    <!-- ITEMS CONTAINER -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginTop="22dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="26dp"
        app:cardElevation="0dp"
        app:strokeColor="#EFE7DC"
        app:strokeWidth="1dp">

        <ListView
            android:id="@+id/listItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:choiceMode="multipleChoice"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:listSelector="@android:color/transparent"
            android:padding="10dp"/>

    </com.google.android.material.card.MaterialCardView>

    <!-- REFUND SECTION -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/layoutRefundRent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Refund Rent"
            android:textColor="#1A1C1E"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusBottomEnd="20dp"
            app:boxCornerRadiusBottomStart="20dp"
            app:boxCornerRadiusTopEnd="20dp"
            app:boxCornerRadiusTopStart="20dp"
            app:boxStrokeColor="#D6C7B2"
            app:boxStrokeWidth="1dp"
            app:hintEnabled="false"
            app:prefixText="₹ "
            app:prefixTextColor="#1A1C1E"
            app:startIconTint="#9E8D7A">

            <EditText
                android:id="@+id/etRefundRent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="sans-serif-medium"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:padding="18dp"
                android:textColor="#1A1C1E"
                android:textSize="18sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/layoutRefundDeposit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deposit Refund"
            android:textColor="#1A1C1E"
            android:textSize="16sp"
            android:textStyle="bold"/>


        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:boxBackgroundColor="#FFFFFF"
            app:boxCornerRadiusBottomEnd="20dp"
            app:boxCornerRadiusBottomStart="20dp"
            app:boxCornerRadiusTopEnd="20dp"
            app:boxCornerRadiusTopStart="20dp"
            app:boxStrokeColor="#D6C7B2"
            app:boxStrokeWidth="1dp"
            app:hintEnabled="false"
            app:prefixText="₹ "
            app:prefixTextColor="#1A1C1E"
            app:startIconTint="#9E8D7A">

            <EditText
                android:id="@+id/etRefundDeposit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="sans-serif-medium"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:padding="18dp"
                android:textColor="#1A1C1E"
                android:textSize="18sp"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

</LinearLayout>