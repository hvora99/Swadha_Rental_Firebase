<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="#FCFAF7"
    app:cardCornerRadius="26dp"
    app:cardElevation="0dp"
    app:strokeColor="#EFE7DC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TOP ROW -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- ITEM CODE -->

            <TextView
                android:id="@+id/tvItemCircle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_item_chip"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="CT09"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- STATUS -->

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FFF3E0"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:text="BOOKED"
                android:textColor="#EF6C00"
                android:textSize="11sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- CUSTOMER NAME -->



        <TextView
            android:id="@+id/tvBookingName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="sans-serif-medium"
            android:text="Priya Shah"
            android:textColor="#1A1C1E"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <!-- PHONE -->

        <TextView
            android:id="@+id/tvBookingPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="9876543210"
            android:textColor="#8E8E93"
            android:textSize="13sp"/>

        <!-- DATE SECTION -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- PICKUP -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pickup"
                    android:textColor="#8E8E93"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvBookingPickup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="07 Aug"
                    android:textColor="#1A1C1E"
                    android:textSize="08sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- ARROW -->

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_arrow_forward"
                app:tint="#B0B0B0"/>

            <!-- RETURN -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Return"
                    android:textColor="#8E8E93"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvBookingReturn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="08 Aug"
                    android:textColor="#800020"
                    android:textSize="08sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- BOTTOM BALANCE -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="5sp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending Balance"
                android:textColor="#8E8E93"
                android:textSize="12sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/tvBookingBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹1200"
                android:textColor="#1A1C1E"
                android:textSize="22sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>